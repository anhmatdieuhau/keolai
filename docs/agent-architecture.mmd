---
title: "Rõ bài toán lớn: AI Marketing Agent System"
---
%% Bài toán: Làm sao để tự động hoá vòng lặp Marketing?
%% 1. Research keyword trên Google → tổng hợp report
%% 2. Report về Group duyệt → viết bài cho Website, Facebook, Social
%% 3. Cron job lắng nghe comment → AI auto reply tăng tương tác
%% 4. Phân tích hiệu quả → feed back keyword mới → lặp lại

flowchart TB
    subgraph DATA["☁️ Data Sources"]
        direction LR
        D1["🔍 Google Search<br/>SERP Results"]
        D2["📊 GSC<br/>Rankings & CTR"]
        D3["📈 GA4<br/>Traffic & Behavior"]
        D4["📘 Facebook<br/>Insights & Comments"]
        D5["🏪 Competitor<br/>Content & Ads"]
    end

    subgraph STRATEGY["🧠 Strategy & Planning"]
        direction TB

        HUMAN_S["👤 Human<br/>(Strategic Input)<br/>─────────────<br/>Chọn keyword<br/>Định hướng nội dung"]

        RA["🤖 Research Agent<br/>─────────────────────<br/>Purpose: Thu thập data từ<br/>nhiều nguồn, phân tích<br/>đối thủ & thị trường,<br/>xuất research report"]

        REPORT["📋 Artifact: Research Report<br/>─────────────<br/>• Keyword gaps<br/>• Content briefs<br/>• Competitor insights"]

        HUMAN_S -->|"keyword<br/>input"| RA
        RA --> REPORT
    end

    REVIEW["👤 Human Review<br/>──────────────<br/>Duyệt report trên Group<br/>✅ Approve / 🔄 Reject"]

    subgraph EXECUTION["✍️ Content Creation & Distribution"]
        direction TB

        CA["🤖 Content Agent<br/>─────────────────────<br/>Purpose: Nhận brief đã duyệt,<br/>viết bài SEO tối ưu,<br/>tạo nhiều format cho<br/>từng kênh phân phối"]

        ARTIFACT["📄 Artifact: Content Package<br/>─────────────<br/>• Bài website HTML<br/>• Post Facebook<br/>• Post Social"]

        subgraph CHANNELS["📢 Kênh Phân Phối"]
            direction LR
            CH1["🌐 Website"]
            CH2["📘 Facebook"]
            CH3["📱 Social Media"]
        end

        CA --> ARTIFACT
        ARTIFACT --> CHANNELS
    end

    subgraph ENGAGE["💬 Engagement & Interaction"]
        direction TB

        EA["🤖 Engagement Agent<br/>─────────────────────<br/>Purpose: Lắng nghe comment<br/>trên các kênh, AI tự động<br/>trả lời phù hợp, tăng<br/>tương tác & giữ chân user"]

        LOG["🗄️ Conversation Log<br/>Lưu lịch sử tương tác"]

        EA --> LOG
    end

    subgraph ANALYSIS["📊 Analysis & Learning"]
        direction TB

        AA["🤖 Analyst Agent<br/>─────────────────────<br/>Purpose: Tổng hợp metrics<br/>từ tất cả kênh, đánh giá<br/>hiệu quả content, đề xuất<br/>cải thiện cho vòng tiếp"]

        INSIGHT["💡 Artifact: Insights<br/>─────────────<br/>• Top performing content<br/>• Keyword opportunities<br/>• Engagement patterns"]

        AA --> INSIGHT
    end

    DATA --> RA
    REPORT --> REVIEW
    REVIEW -->|"✅ Approved"| CA
    REVIEW -->|"🔄 Reject"| RA
    CHANNELS --> EA
    D4 -->|"new comments"| EA
    CHANNELS --> AA
    DATA --> AA
    INSIGHT -->|"♻️ Feed back<br/>next cycle"| HUMAN_S

